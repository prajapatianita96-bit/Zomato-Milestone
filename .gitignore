# .gitignore — Zomato AI Recommendation System

# ── Secrets & Environment ──────────────────────
.env
*.env.local

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ───────────────────────
venv/
.venv/
env/
ENV/

# ── Dataset Cache ─────────────────────────────
data/zomato_dataset.pkl
data/*.pkl
data/*.csv

# ── LLM Response Logs ─────────────────────────
output/
logs/

# ── IDE & OS ──────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Pytest ────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
